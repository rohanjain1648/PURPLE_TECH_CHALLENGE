# Copy to .env and edit before running locally (docker-compose sets these automatically)

# For local dev with SQLite (no Postgres needed):
DATABASE_URL=sqlite+aiosqlite:///./store_intelligence.db

# For production (matches docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://si_user:si_pass@localhost:5432/store_intelligence

DEBUG=false

# Anomaly thresholds (override as needed)
QUEUE_SPIKE_THRESHOLD=5
QUEUE_CRITICAL_THRESHOLD=10
CONVERSION_DROP_PCT=0.20
DEAD_ZONE_MINUTES=30
STALE_FEED_MINUTES=10
POS_CORRELATION_WINDOW_S=300
REENTRY_MAX_GAP_S=300
